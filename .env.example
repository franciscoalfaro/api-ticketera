EMAIL_USER=email@email.com
EMAIL_PASSWORD=keyemail

SECRET_KEY=key_generate
REFRESH_SECRET_KEY=SECRET_KEY_PROYECT_Refresh


MONGODB_URI=mongodb://localhost:27017/DatabaseName

# IA Ticket Agent
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_TIMEOUT_MS=30000
AI_OLLAMA_MODEL=qwen2.5-coder:1.5b-base

# Opcional: lista de modelos para fallback (coma separados)
# Primer bloque: interpretar intención de la pregunta
AI_OLLAMA_INTERPRETER_MODELS=minimax-m2:cloud,qwen2.5-coder:1.5b-base

# Segundo bloque: redactar respuesta final al usuario
AI_OLLAMA_RESPONDER_MODELS=minimax-m2:cloud,gpt-oss:120b-cloud,qwen2.5-coder:1.5b-base

COMPANY_PREFIX=Prefijo_empresa

PORT=3012

# URL donde Microsoft redirige después del login
MICROSOFT_REDIRECT_URI=http://localhost:5173/api/microsoft/callback

# Credenciales de tu aplicación registrada en Azure AD
JWT_SECRET=acatusecreto

#Id. de aplicación (cliente)
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

#Id. de directorio (inquilino)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

#corresponde al valor de en secretos del cliente
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

MS_GRAPH_SCOPE=https://graph.microsoft.com/.default

SUPPORT_MAILBOX=soporte@empresa.com